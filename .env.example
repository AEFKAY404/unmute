NODE_ENV=development
PORT=3000

# Required before production
ADMIN_DASHBOARD_PASSWORD=replace-with-a-strong-password
ADMIN_DASHBOARD_SECRET=replace-with-a-long-random-secret

# Required for signed moderator links
ADMIN_SIGNING_SECRET=replace-with-a-long-random-secret

# Optional comma-separated blocked words
BLOCKED_WORDS=word1,word2

# Optional extra allowed origins for Socket.IO clients
# ALLOWED_CLIENT_ORIGINS=https://your-site.com,https://another-site.com
